<?xml version="1.0" encoding="utf-8"?>
<!-- Placeholder hero image: gradient rectangle simulating a modern clinic interior -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base gradient: soft blue to lighter blue -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#B3D1E8"
                android:centerColor="#D2E6EF"
                android:endColor="#E8F0F5"
                android:angle="135" />
        </shape>
    </item>
    <!-- Diagonal accent stripe -->
    <item
        android:top="200dp"
        android:bottom="200dp"
        android:left="0dp"
        android:right="0dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#1A003F87"
                android:endColor="#00003F87"
                android:angle="45" />
        </shape>
    </item>
</layer-list>
