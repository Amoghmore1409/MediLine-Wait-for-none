<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/patient_home_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface">

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent"
        android:layout_marginBottom="64dp" android:scrollbars="none">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:paddingTop="24dp" android:paddingBottom="24dp">

            <!-- Top bar -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
                android:gravity="center_vertical" android:orientation="horizontal"
                android:paddingStart="24dp" android:paddingEnd="24dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <FrameLayout android:layout_width="32dp" android:layout_height="32dp"
                        android:background="@drawable/bg_primary_gradient">
                        <ImageView android:layout_width="18dp" android:layout_height="18dp"
                            android:layout_gravity="center" android:src="@drawable/ic_medical_services"
                            android:contentDescription="@string/brand_name" />
                    </FrameLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginStart="10dp" android:fontFamily="sans-serif-black"
                        android:text="@string/brand_name" android:textColor="@color/primary"
                        android:textSize="18sp" android:textStyle="bold|italic" />
                </LinearLayout>
                <FrameLayout android:layout_width="40dp" android:layout_height="40dp"
                    android:background="@drawable/bg_profile_circle">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp"
                        android:layout_gravity="center" android:src="@drawable/ic_person_outline"
                        android:contentDescription="@string/nav_profile" />
                </FrameLayout>
            </LinearLayout>

            <!-- Hero Search Section -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginStart="24dp" android:layout_marginTop="16dp"
                android:layout_marginEnd="24dp" android:background="@drawable/bg_cta_button"
                android:elevation="4dp" android:orientation="vertical"
                android:padding="32dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black" android:text="@string/patient_hero_title"
                    android:textColor="@color/white" android:textSize="28sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="8dp" android:text="@string/patient_hero_subtitle"
                    android:textColor="@color/primary_fixed" android:textSize="14sp" />
                <EditText android:id="@+id/patient_search" android:layout_width="match_parent"
                    android:layout_height="48dp" android:layout_marginTop="24dp"
                    android:background="@drawable/bg_input_field" android:elevation="4dp"
                    android:hint="@string/patient_search_hint" android:inputType="text"
                    android:paddingStart="16dp" android:paddingEnd="16dp"
                    android:textColor="@color/on_surface" android:textColorHint="@color/outline"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Categories -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="32dp" android:gravity="center_vertical"
                android:orientation="horizontal" android:paddingStart="24dp"
                android:paddingEnd="24dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:fontFamily="sans-serif-medium"
                    android:text="@string/patient_categories" android:textColor="@color/on_surface"
                    android:textSize="20sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/patient_view_all" android:textColor="@color/primary"
                    android:textSize="13sp" android:textStyle="bold" />
            </LinearLayout>
            <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="16dp" android:clipToPadding="false"
                android:paddingStart="24dp" android:paddingEnd="24dp"
                android:scrollbars="none">
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:id="@+id/category_all" android:layout_width="wrap_content" android:layout_height="44dp"
                        android:layout_marginEnd="12dp" android:background="@drawable/bg_category_active"
                        android:gravity="center" android:paddingStart="20dp"
                        android:paddingEnd="20dp" android:text="All"
                        android:textColor="@color/white" android:textSize="13sp"
                        android:textStyle="bold" android:clickable="true" android:focusable="true"/>
                    <TextView android:id="@+id/category_general" android:layout_width="wrap_content" android:layout_height="44dp"
                        android:layout_marginEnd="12dp" android:background="@drawable/bg_category_inactive"
                        android:gravity="center" android:paddingStart="20dp"
                        android:paddingEnd="20dp" android:text="General"
                        android:textColor="@color/on_surface_variant" android:textSize="13sp"
                        android:textStyle="bold" android:clickable="true" android:focusable="true"/>
                    <TextView android:id="@+id/category_pediatrics" android:layout_width="wrap_content" android:layout_height="44dp"
                        android:layout_marginEnd="12dp" android:background="@drawable/bg_category_inactive"
                        android:gravity="center" android:paddingStart="20dp"
                        android:paddingEnd="20dp" android:text="Pediatrics"
                        android:textColor="@color/on_surface_variant" android:textSize="13sp"
                        android:textStyle="bold" android:clickable="true" android:focusable="true"/>
                    <TextView android:id="@+id/category_dentistry" android:layout_width="wrap_content" android:layout_height="44dp"
                        android:layout_marginEnd="12dp" android:background="@drawable/bg_category_inactive"
                        android:gravity="center" android:paddingStart="20dp"
                        android:paddingEnd="20dp" android:text="Dentistry"
                        android:textColor="@color/on_surface_variant" android:textSize="13sp"
                        android:textStyle="bold" android:clickable="true" android:focusable="true"/>
                    <TextView android:id="@+id/category_cardiology" android:layout_width="wrap_content" android:layout_height="44dp"
                        android:layout_marginEnd="12dp" android:background="@drawable/bg_category_inactive"
                        android:gravity="center" android:paddingStart="20dp"
                        android:paddingEnd="20dp" android:text="Cardiology"
                        android:textColor="@color/on_surface_variant" android:textSize="13sp"
                        android:textStyle="bold" android:clickable="true" android:focusable="true"/>
                    <TextView android:id="@+id/category_dermatology" android:layout_width="wrap_content" android:layout_height="44dp"
                        android:layout_marginEnd="12dp" android:background="@drawable/bg_category_inactive"
                        android:gravity="center" android:paddingStart="20dp"
                        android:paddingEnd="20dp" android:text="Dermatology"
                        android:textColor="@color/on_surface_variant" android:textSize="13sp"
                        android:textStyle="bold" android:clickable="true" android:focusable="true"/>
                    <TextView android:id="@+id/category_neurology" android:layout_width="wrap_content" android:layout_height="44dp"
                        android:layout_marginEnd="12dp" android:background="@drawable/bg_category_inactive"
                        android:gravity="center" android:paddingStart="20dp"
                        android:paddingEnd="20dp" android:text="Neurology"
                        android:textColor="@color/on_surface_variant" android:textSize="13sp"
                        android:textStyle="bold" android:clickable="true" android:focusable="true"/>
                    <TextView android:id="@+id/category_orthopedics" android:layout_width="wrap_content" android:layout_height="44dp"
                        android:layout_marginEnd="12dp" android:background="@drawable/bg_category_inactive"
                        android:gravity="center" android:paddingStart="20dp"
                        android:paddingEnd="20dp" android:text="Orthopedics"
                        android:textColor="@color/on_surface_variant" android:textSize="13sp"
                        android:textStyle="bold" android:clickable="true" android:focusable="true"/>
                </LinearLayout>
            </HorizontalScrollView>

            <!-- Nearby Clinics -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="32dp" android:orientation="vertical"
                android:paddingStart="24dp" android:paddingEnd="24dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium" android:text="@string/patient_nearby_clinics"
                    android:textColor="@color/on_surface" android:textSize="20sp"
                    android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="4dp" android:text="@string/patient_nearby_subtitle"
                    android:textColor="@color/on_secondary_container" android:textSize="13sp" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/patient_clinic_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:paddingStart="24dp"
                android:paddingEnd="24dp" />
        </LinearLayout>
    </ScrollView>

    <!-- Bottom Nav -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="64dp"
        android:layout_gravity="bottom" android:background="@color/surface_container_lowest"
        android:elevation="8dp" android:gravity="center_vertical"
        android:orientation="horizontal" android:paddingStart="8dp"
        android:paddingEnd="8dp">
        <LinearLayout android:id="@+id/nav_home" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical"
            android:clickable="true" android:focusable="true">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@drawable/ic_medical_services_white" app:tint="@color/primary" android:contentDescription="@string/nav_home" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_home" android:textColor="@color/primary"
                android:textSize="11sp" android:textStyle="bold" />
        </LinearLayout>
        <LinearLayout android:id="@+id/nav_queue" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical"
            android:clickable="true" android:focusable="true">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@drawable/ic_update" android:contentDescription="@string/nav_queue" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_queue" android:textColor="@color/outline"
                android:textSize="11sp" />
        </LinearLayout>
        <LinearLayout android:id="@+id/nav_bookings" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical"
            android:clickable="true" android:focusable="true">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@drawable/ic_event_available" android:contentDescription="@string/nav_bookings" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_bookings" android:textColor="@color/outline"
                android:textSize="11sp" />
        </LinearLayout>
        <LinearLayout android:id="@+id/nav_profile" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical"
            android:clickable="true" android:focusable="true">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@drawable/ic_person_outline" android:contentDescription="@string/nav_profile" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_profile" android:textColor="@color/outline"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
