<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/queue_status_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:gravity="center_horizontal" android:orientation="vertical"
        android:paddingStart="24dp" android:paddingTop="24dp"
        android:paddingEnd="24dp" android:paddingBottom="32dp">

        <!-- Back + Brand -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
            android:gravity="center_vertical" android:orientation="horizontal">
            <ImageView android:id="@+id/queue_back_btn" android:layout_width="32dp"
                android:layout_height="32dp" android:clickable="true" android:focusable="true"
                android:rotation="180" android:src="@drawable/ic_arrow_forward"
                android:contentDescription="Back" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_marginStart="12dp" android:layout_weight="1"
                android:fontFamily="sans-serif-black" android:text="@string/brand_name"
                android:textColor="@color/primary" android:textSize="18sp"
                android:textStyle="bold|italic" />
        </LinearLayout>

        <!-- Token + Wait Bento -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="8dp" android:baselineAligned="false"
            android:orientation="horizontal">
            <!-- Your Token Card -->
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_marginEnd="8dp" android:layout_weight="1"
                android:background="@drawable/bg_card_surface_low" android:gravity="center"
                android:minHeight="180dp" android:orientation="vertical" android:padding="24dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium" android:letterSpacing="0.08"
                    android:text="@string/queue_your_token" android:textAllCaps="true"
                    android:textColor="@color/on_surface_variant" android:textSize="11sp"
                    android:textStyle="bold" />
                <TextView android:id="@+id/queue_token" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:layout_marginTop="8dp"
                    android:fontFamily="sans-serif-black" android:text="#--"
                    android:textColor="@color/primary" android:textSize="56sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="8dp" android:background="@drawable/bg_token_badge"
                    android:paddingStart="16dp" android:paddingTop="6dp"
                    android:paddingEnd="16dp" android:paddingBottom="6dp"
                    android:text="@string/queue_active_session"
                    android:textColor="@color/on_primary_fixed" android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>
            <!-- Wait Time Card -->
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_marginStart="8dp" android:layout_weight="1"
                android:background="@drawable/bg_cta_button" android:elevation="4dp"
                android:minHeight="180dp" android:orientation="vertical"
                android:padding="24dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium" android:letterSpacing="0.08"
                    android:text="@string/queue_est_wait_label" android:textAllCaps="true"
                    android:textColor="@color/primary_fixed_dim" android:textSize="11sp"
                    android:textStyle="bold" />
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="8dp" android:gravity="bottom"
                    android:orientation="horizontal">
                    <TextView android:id="@+id/queue_wait_time" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:fontFamily="sans-serif-medium"
                        android:text="--" android:textColor="@color/white"
                        android:textSize="48sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginStart="4dp" android:layout_marginBottom="8dp"
                        android:text="@string/queue_mins" android:textColor="#CCFFFFFF"
                        android:textSize="16sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Currently Serving -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="16dp" android:background="@drawable/bg_role_card"
            android:elevation="1dp" android:orientation="vertical" android:padding="32dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:gravity="center_vertical" android:orientation="horizontal">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/queue_current_serving" android:textColor="@color/on_surface"
                        android:textSize="22sp" android:textStyle="bold" />
                    <TextView android:id="@+id/queue_clinic_info" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:layout_marginTop="4dp"
                        android:textColor="@color/on_surface_variant" android:textSize="13sp" />
                </LinearLayout>
                <TextView android:id="@+id/queue_serving_number" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:fontFamily="sans-serif-black"
                    android:text="#--" android:textColor="@color/secondary" android:textSize="36sp" />
            </LinearLayout>
            <!-- Progress bar -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="24dp" android:orientation="vertical">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:id="@+id/queue_progress_current" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:fontFamily="sans-serif-medium" android:letterSpacing="0.08"
                        android:textAllCaps="true" android:textColor="@color/on_surface_variant"
                        android:textSize="10sp" android:textStyle="bold" />
                    <TextView android:id="@+id/queue_progress_target" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.08" android:textAllCaps="true"
                        android:textColor="@color/on_surface_variant" android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>
                <ProgressBar android:id="@+id/queue_progress" android:layout_width="match_parent"
                    android:layout_height="20dp" android:layout_marginTop="8dp"
                    android:max="100" android:progress="73"
                    android:progressDrawable="@drawable/bg_progress_indicator"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal" />
                <TextView android:id="@+id/queue_ahead_text" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:layout_gravity="center"
                    android:layout_marginTop="8dp" android:textColor="@color/on_surface_variant"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Stay Nearby Card -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="16dp" android:background="@drawable/bg_card_surface_low"
            android:gravity="center_vertical" android:orientation="horizontal" android:padding="20dp">
            <FrameLayout android:layout_width="48dp" android:layout_height="48dp"
                android:layout_marginEnd="16dp" android:background="@drawable/bg_token_badge">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:layout_gravity="center" android:src="@drawable/ic_update"
                    android:contentDescription="@string/queue_stay_nearby" />
            </FrameLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/queue_stay_nearby" android:textColor="@color/on_surface"
                    android:textSize="15sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="2dp" android:text="@string/queue_stay_nearby_desc"
                    android:textColor="@color/on_surface_variant" android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Notification + Check-in -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="16dp" android:background="@drawable/bg_feature_card"
            android:gravity="center_vertical" android:orientation="vertical"
            android:padding="24dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:gravity="center_vertical" android:orientation="horizontal">
                <ImageView android:layout_width="36dp" android:layout_height="36dp"
                    android:layout_marginEnd="16dp" android:src="@drawable/ic_update"
                    android:contentDescription="@string/queue_notifications_on" />
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/queue_notifications_on" android:textColor="@color/on_surface"
                        android:textSize="15sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="2dp" android:text="@string/queue_notifications_desc"
                        android:textColor="@color/on_surface_variant" android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>
            <FrameLayout android:id="@+id/queue_checkin_btn" android:layout_width="match_parent"
                android:layout_height="48dp" android:layout_marginTop="20dp"
                android:background="@drawable/bg_cta_button" android:clickable="true"
                android:elevation="4dp" android:focusable="true"
                android:foreground="?attr/selectableItemBackground">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_gravity="center" android:text="@string/queue_checkin"
                    android:textColor="@color/white" android:textSize="14sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <TextView android:id="@+id/queue_cancel_btn" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:layout_gravity="center"
                android:layout_marginTop="16dp" android:text="Cancel Appointment"
                android:textColor="#F44336" android:textSize="14sp"
                android:textStyle="bold" android:clickable="true" android:focusable="true"
                android:padding="8dp"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
